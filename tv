#!/bin/bash
# Quick launcher for IPTV
# Usage: tv              → post-Soviet channels in IINA
#        tv us           → US channels in IINA
#        tv rebuild      → pull upstream + rebuild playlists
#        tv serve        → start local server for Apple TV
#        tv list         → show available playlists

DIR="$(cd "$(dirname "$0")" && pwd)"
OUTPUT="$DIR/output"
BUILD="$DIR/build.py"
SERVE="$DIR/serve.py"

case "${1:-}" in
  us|usa)
    open -a IINA "$OUTPUT/us-tv.m3u"
    ;;
  rebuild)
    echo "📡 Updating upstream repos..."
    (cd "$DIR/upstream/iptv-org" && git pull -q)
    (cd "$DIR/upstream/free-tv" && git pull -q)
    echo "Downloading latest channel database..."
    curl -sL "https://raw.githubusercontent.com/iptv-org/database/master/data/channels.csv" \
      -o "$DIR/upstream/channels.csv"
    echo "🔨 Rebuilding playlists..."
    python3 "$BUILD"
    # Auto-push to gist if set up
    GIST_FILE="$DIR/.gist-id"
    if [ -f "$GIST_FILE" ] && command -v gh &>/dev/null; then
      GIST_ID=$(cat "$GIST_FILE")
      echo "📡 Pushing to gist..."
      python3 -c "
import json, subprocess, urllib.request
gist_id = '$GIST_ID'
files = {}
for name in ['post-soviet-tv.m3u', 'us-tv.m3u']:
    with open('$OUTPUT/' + name, 'r') as f:
        files[name] = {'content': f.read()}
token = subprocess.check_output(['gh', 'auth', 'token']).decode().strip()
req = urllib.request.Request(f'https://api.github.com/gists/{gist_id}',
    data=json.dumps({'files': files}).encode(),
    headers={'Authorization': f'token {token}', 'Content-Type': 'application/json'},
    method='PATCH')
urllib.request.urlopen(req)
print('✅ iPlayTV playlists updated')
"
    fi
    ;;
  serve)
    python3 "$SERVE"
    ;;
  list)
    echo "Available playlists:"
    ls -1 "$OUTPUT"/*.m3u "$OUTPUT"/*.m3u8 2>/dev/null | while read f; do
      name=$(basename "$f")
      count=$(grep -c 'EXTINF' "$f" 2>/dev/null || echo 0)
      echo "  $name ($count channels)"
    done
    ;;
  *)
    open -a IINA "$OUTPUT/post-soviet-tv.m3u"
    ;;
esac
